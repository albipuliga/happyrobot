REQUEST_TIMEOUT_SECONDS=10
NEGOTIATION_MAX_COUNTER_ROUNDS=3

# Dashboard settings (optional)
DASHBOARD_SESSION_MAX_AGE_SECONDS=14400
DASHBOARD_SESSION_COOKIE_NAME=happyrobot_dashboard_session
SEED=false

# Set to true in production (Railway handles TLS termination)
SESSION_HTTPS_ONLY=false

# For Railway production, set DATABASE_URL to ${{Postgres.DATABASE_URL}} on the app service.
# For local development without Postgres, you can keep SQLite:
DATABASE_URL=sqlite:///./happyrobot.db

APP_API_KEY=replace-with-a-generated-secret
FMCSA_API_KEY=
FMCSA_BASE_URL=https://mobile.fmcsa.dot.gov/qc/services
